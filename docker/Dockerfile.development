FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    ninja-build \
    git \
    python3 \
    python3-dev \
    python3-pip \
    libspdlog-dev \
    libfmt-dev \
    && rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir pybind11

WORKDIR /workspace